# Tenderly Virtual Network RPC endpoint (replace with your own key if needed)
VITE_TENDERLY_RPC=https://virtual.mainnet.eu.rpc.tenderly.co/a5b0561f-8857-4a09-a786-b93f6ed43efe
# Custom chain ID for your Tenderly Virtual Network (must NOT be 1)
VITE_TENDERLY_CHAIN_ID=73571
# Circles recipient address
VITE_CIRCLES_RECIPIENT=0x414e8Eae989Ba265a1555e1Fc744De8ee02947F1
# Gas payer address (pre-fills the UI; set to recipient to self-fund gas)
VITE_GAS_PAYER_ADDRESS=0x414e8Eae989Ba265a1555e1Fc744De8ee02947F1

# StearCode integration (stearcode.com) — optional
# Set your API key to auto-connect and sync configuration on startup
VITE_STEARCODE_API_KEY=
# Override the default StearCode API endpoint (leave empty to use https://api.stearcode.com)
VITE_STEARCODE_ENDPOINT=
