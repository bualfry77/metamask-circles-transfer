# ── Front-end (Vite) ──────────────────────────────────────────────────────────
# Tenderly Virtual Mainnet RPC (used for read-only balance/allowance queries)
VITE_TENDERLY_RPC=https://virtual.mainnet.eu.rpc.tenderly.co/YOUR_TENDERLY_KEY

# Circles network recipient address
VITE_CIRCLES_RECIPIENT=0xYourCirclesAddressHere

# Circles seed address (informational)
VITE_CIRCLES_SEED_ADDRESS=0xCirclesSeedAddressHere

# Deployed CirclesTransfer contract address — set this after running `npm run deploy:sepolia`
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# ── Hardhat deployment ────────────────────────────────────────────────────────
# Private key of the deployer wallet (without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# RPC URL for the Sepolia testnet (e.g. from Alchemy, Infura, or Tenderly)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Optional: Goerli testnet RPC URL
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_KEY

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# USDC address override for testnets (leave blank to use Ethereum mainnet USDC)
# USDC_ADDRESS=0xYourTestnetUSDCAddressHere

# Circles recipient for deploy script (can differ from VITE_CIRCLES_RECIPIENT)
CIRCLES_RECIPIENT=0xYourCirclesAddressHere
